# --- APP ---
APP_ENV=local
APP_DEBUG=false
# IMPORTANTE: gere uma chave aleatória de 32 caracteres em:
# https://www.browserling.com/tools/random-string
APP_KEY=bdkkwqxatxnvegsrqnzakgrmoofxpxug

# URL onde o Firefly vai rodar (Railway vai gerar automaticamente)
APP_URL=https://SEU_DOMINIO_RAILWAY.up.railway.app

# --- BANCO DE DADOS SUPABASE ---
DB_CONNECTION=pgsql
DB_HOST=aws-0-us-west-2.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.wqajkohquvoukljpkqet
DB_PASSWORD=xBDAsgOrxgkQdcCw

# --- LOCALIZAÇÃO ---
TZ=America/Sao_Paulo
DEFAULT_LANGUAGE=pt_BR
DEFAULT_LOCALE=pt_BR
APP_LOG_LEVEL=info

# --- CACHE / SESSÃO ---
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# --- EMAIL (log para não precisar configurar SMTP agora) ---
MAIL_MAILER=log

# --- AUTENTICAÇÃO ---
AUTHENTICATION_GUARD=web
COOKIE_SAMESITE=lax
DISABLE_FRAME_HEADER=false
DISABLE_CSP_HEADER=false

# --- MOEDA PADRÃO ---
# BRL = Real Brasileiro
DEFAULT_CURRENCY=BRL

# --- OUTROS ---
FIREFLY_III_LAYOUT=v1
SEND_REGISTRATION_MAIL=false
SEND_ERROR_MESSAGE=false
ENABLE_EXTERNAL_MAP=true
ENABLE_EXTERNAL_RATES=true
MAP_DEFAULT_LAT=-18.9113
MAP_DEFAULT_LONG=-48.2622
MAP_DEFAULT_ZOOM=13
TRUSTED_PROXIES=**
